# --- Labels (required; or set in config.yaml) ---
LABELS='["auto-labeled","needs-review"]'

# --- Plex (remove if not using Plex) ---
PLEX_URL=http://plex.local:32400
PLEX_TOKEN=xxxxxxxxxxxxxxxxxxxx
PLEX_LIBRARY_TYPES='["movie","show"]'

# --- Jellyfin (remove if not using Jellyfin) ---
JELLYFIN_URL=http://jellyfin.local:8096
JELLYFIN_API_KEY=xxxxxxxxxxxxxxxxxxxx
JELLYFIN_ITEM_TYPES='["Movie","Episode","Series"]'

# --- Webhook security (optional) ---
# WEBHOOK_TOKEN=your-secret-token

# --- Server ---
BIND_HOST=0.0.0.0
BIND_PORT=8080

# --- Config path ---
# CONFIG_PATH=/config/config.yaml

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=/var/log/tagarr/app.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
